{
    "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
    "runtime": {
        "version": "Lua 5.1",
        "builtin": {
            "io": "disable",
            "os": "disable",
            "package": "disable",
            "debug": "disable",
            "coroutine": "disable"
        }
    },
    "diagnostics": {
        "globals": [
            "CreateFrame", "UIParent", "GameTooltip", "Settings",
            "SlashCmdList", "InCombatLockdown", "UnitClass", "UnitName",
            "UnitLevel", "GetZoneText", "RAID_CLASS_COLORS",
            "C_Timer", "C_AddOns", "C_Spell", "C_UnitAuras",
            "hooksecurefunc", "issecretvalue", "PlaySound", "SOUNDKIT",
            "BackdropTemplateMixin", "GameFontNormalLarge", "GameFontNormal",
            "format", "strsplit", "tinsert", "tremove", "wipe",
            "AddonCompartmentFrame"
        ]
    },
    "workspace": {
        "ignoreDir": [
            "Libs",
            ".release"
        ]
    }
}
